# Gateway runtime
PORT=20129
DATABASE_URL=postgres://nexusai:replace-with-local-postgres-password@localhost:5432/nexusai_gateway?sslmode=disable
REDIS_URL=redis://localhost:6379/1
OIDC_ISSUER=http://localhost:8088/realms/nexusai

# Bootstrap / compatibility values for local development only.
# Production values must come from a secret store.
INITIAL_PASSWORD=replace-with-local-bootstrap-password
OMNIROUTE_ADMIN_KEY=replace-with-local-admin-key

# Upstream provider integration
UPSTREAM_API_URL=
UPSTREAM_API_KEY=
